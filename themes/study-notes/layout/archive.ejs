<section class="archive">
  <h1>归档</h1>
  <% let lastYear = null; %>
  <% page.posts.each(function(post) { %>
    <% const year = date(post.date, 'YYYY'); %>
    <% if (year !== lastYear) { %>
      <% if (lastYear !== null) { %></div><% } %>
      <h2><%= year %></h2>
      <div class="archive-list">
      <% lastYear = year; %>
    <% } %>
    <a class="archive-item" href="<%= url_for(post.path) %>">
      <time><%= date(post.date, 'MM-DD') %></time>
      <span><%= post.title %></span>
    </a>
  <% }) %>
  <% if (page.posts.length) { %></div><% } %>
</section>
