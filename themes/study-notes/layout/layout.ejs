<!doctype html>
<html lang="<%= config.language || 'zh-CN' %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="<%= config.description %>">
    <title><% if (page.title) { %><%= page.title %> | <% } %><%= config.title %></title>
    <%- css('css/style') %>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <a class="site-title" href="<%= url_for('/') %>"><%= config.title %></a>
        <nav class="site-nav" aria-label="Primary">
          <% const menu = theme.menu || {}; %>
          <% Object.keys(menu).forEach(function(name) { %>
            <a href="<%= url_for(menu[name]) %>"><%= name %></a>
          <% }) %>
        </nav>
      </div>
    </header>
    <main class="wrap site-main">
      <%- body %>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <span><%= config.title %></span>
        <span>记录、复盘、继续变强。</span>
      </div>
    </footer>
  </body>
</html>
